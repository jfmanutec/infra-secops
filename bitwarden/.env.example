# ============================================================
# VAULTWARDEN - Variaveis de Ambiente
# ============================================================

TZ=America/Fortaleza

VW_PORT_EXTERNAL=8082
VW_PORT_INTERNAL=80

VW_DATA_PATH=./data/vaultwarden
VW_PGDATA_PATH=./data/postgres

POSTGRES_DB=vaultwarden
POSTGRES_USER=vaultwarden_admin
POSTGRES_PASSWORD='CHANGE_ME_VAULTWARDEN_DB_PASSWORD'

DATABASE_URL=postgresql://vaultwarden_admin:CHANGE_ME_VAULTWARDEN_DB_PASSWORD@postgres-vaultwarden:5432/vaultwarden

DOMAIN=https://cofre.example.local
ADMIN_TOKEN='CHANGE_ME_VAULTWARDEN_ADMIN_TOKEN'

SIGNUPS_ALLOWED=false
INVITATIONS_ALLOWED=true
WEBSOCKET_ENABLED=true

ATTACHMENT_LIMIT_ORG=104857600
SENDS_ALLOWED=true

LOG_LEVEL=info
EXTENDED_LOGGING=true

# SMTP_HOST=smtp.example.local
# SMTP_FROM=cofre@example.local
# SMTP_PORT=587
# SMTP_SECURITY=starttls
# SMTP_USERNAME=cofre@example.local
# SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
