# ============================================================
# VAULTWARDEN - Variáveis de Ambiente
# ============================================================

TZ=America/Fortaleza

VW_PORT_EXTERNAL=8082
VW_PORT_INTERNAL=80

VW_DATA_PATH=./data

DOMAIN=https://cofre.example.local
ADMIN_TOKEN='CHANGE_ME_VAULTWARDEN_ADMIN_TOKEN'

SIGNUPS_ALLOWED=false
INVITATIONS_ALLOWED=true
WEBSOCKET_ENABLED=true

ATTACHMENT_LIMIT_ORG=104857600
SENDS_ALLOWED=true

LOG_LEVEL=info
EXTENDED_LOGGING=true

